{
  "schema_version": "0.2",
  "slug": "go-gitea/gitea",
  "name": "Gitea",
  "kind": "image",
  "version": "1.23.7",
  "description": "Self-hosted Git service",
  "upstream": "https://github.com/go-gitea/gitea",
  "license": "MIT",
  "tags": [
    "git",
    "code-hosting",
    "devtools"
  ],
  "source": {
    "type": "upstream",
    "image": "gitea/gitea:1.23.7-rootless",
    "maintainer": "official"
  },
  "image": "gitea/gitea:1.23.7-rootless",
  "image_digest": "",
  "arch": [
    "amd64",
    "arm64"
  ],
  "ports": [
    {
      "name": "http",
      "container": 3000,
      "protocol": "tcp"
    },
    {
      "name": "ssh",
      "container": 2222,
      "protocol": "tcp"
    }
  ],
  "volumes": [
    {
      "name": "data",
      "path": "/var/lib/gitea",
      "persistent": true
    },
    {
      "name": "config",
      "path": "/etc/gitea",
      "persistent": true
    }
  ],
  "env": {
    "GITEA__security__INSTALL_LOCK": "true"
  },
  "health_check": "/",
  "update_policy": "manual",
  "display": {
    "icon": "icons/gitea.svg",
    "category": "dev-tools",
    "long_description": "Gitea is a self-hosted Git service like GitHub, written in Go. Fast, runs anywhere, includes issues, pull requests, releases, and a wiki."
  },
  "requirements": {
    "min_ram_mb": 256
  }
}
