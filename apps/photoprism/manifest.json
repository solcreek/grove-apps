{
  "schema_version": "0.1",
  "slug": "photoprism",
  "name": "PhotoPrism",
  "kind": "image",
  "version": "240711",
  "description": "AI-powered photo management — find faces, places, objects in your library",
  "upstream": "https://github.com/photoprism/photoprism",
  "license": "AGPL-3.0",
  "tags": ["photos", "ai", "self-hosted", "google-photos-alternative"],
  "image": "photoprism/photoprism:240711-jammy",
  "image_digest": "",
  "arch": ["amd64", "arm64"],
  "ports": [
    { "name": "http", "container": 2342, "protocol": "tcp" }
  ],
  "volumes": [
    { "name": "originals", "path": "/photoprism/originals", "persistent": true },
    { "name": "storage", "path": "/photoprism/storage", "persistent": true }
  ],
  "env": {
    "PHOTOPRISM_AUTH_MODE": "password",
    "PHOTOPRISM_SITE_URL": "http://localhost:2342/",
    "PHOTOPRISM_DATABASE_DRIVER": "sqlite"
  },
  "secrets": [
    { "name": "PHOTOPRISM_ADMIN_PASSWORD", "generate": "random:32" }
  ],
  "health_check": "/api/v1/status",
  "update_policy": "manual",
  "display": {
    "icon": "icons/photoprism.svg",
    "category": "media",
    "long_description": "PhotoPrism is an AI-powered app for browsing, organizing, and sharing your photo collection — face recognition, location maps, automatic tags. Open-source replacement for Google Photos / Apple Photos cloud sync. SQLite backend for the demo path; MariaDB recommended for libraries past ~10k photos."
  },
  "requirements": {
    "min_ram_mb": 1024
  },
  "setup": {
    "url_path": "/library/browse"
  }
}
