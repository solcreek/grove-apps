{
  "schema_version": "0.3",
  "slug": "louislam/uptime-kuma",
  "name": "Uptime Kuma",
  "version": "2.4.0",
  "description": "Self-hosted uptime / availability monitor",
  "upstream": "https://github.com/louislam/uptime-kuma",
  "license": "MIT",
  "tags": [
    "monitoring",
    "uptime",
    "status-page"
  ],

  "source": {
    "type": "upstream",
    "image": "louislam/uptime-kuma:2.4.0",
    "image_digest": "sha256:91e963bfda569ba115206e843febb446f473ab525add4e08b2b9e3beffa16985",
    "maintainer": "official"
  },

  "arch": ["amd64", "arm64"],

  "services": [
    {
      "name": "app",
      "image": "louislam/uptime-kuma:2.4.0",
      "env": {
        "NODE_ENV": "production"
      },
      "volumes": [
        {
          "name": "data",
          "path": "/app/data",
          "role": "state",
          "init_chown": "1000:1000",
          "backup": { "driver": "filesystem" }
        }
      ],
      "ports": [
        { "name": "http", "container": 3001, "public": true }
      ],
      "health": {
        "type": "http",
        "http": { "path": "/" },
        "start_period_seconds": 30
      }
    }
  ],

  "display": {
    "icon": "icons/uptime-kuma.svg",
    "category": "monitoring",
    "long_description": "A self-hosted alternative to Uptime Robot. Monitors HTTP, TCP, Docker containers, and DNS with a polished UI and rich notification integrations."
  },

  "requirements": {
    "min_ram_mb": 256
  }
}
