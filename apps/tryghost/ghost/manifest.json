{
  "schema_version": "0.2",
  "slug": "tryghost/ghost",
  "name": "Ghost",
  "kind": "image",
  "version": "5.114.1",
  "description": "Professional publishing platform",
  "upstream": "https://github.com/TryGhost/Ghost",
  "license": "MIT",
  "tags": [
    "blog",
    "cms",
    "publishing"
  ],
  "source": {
    "type": "upstream",
    "image": "ghost:5-alpine",
    "maintainer": "official"
  },
  "image": "ghost:5-alpine",
  "image_digest": "",
  "arch": [
    "amd64",
    "arm64"
  ],
  "ports": [
    {
      "name": "http",
      "container": 2368,
      "protocol": "tcp"
    }
  ],
  "volumes": [
    {
      "name": "content",
      "path": "/var/lib/ghost/content",
      "persistent": true
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "database__client": "sqlite3",
    "url": "http://localhost:2368",
    "database__connection__filename": "/var/lib/ghost/content/data/ghost.db"
  },
  "health_check": "/ghost/api/admin/site/",
  "update_policy": "manual",
  "display": {
    "icon": "icons/ghost.svg",
    "category": "productivity",
    "long_description": "Ghost is a publishing platform for modern journalism — fast, SEO-optimised, and built for serious writers, newsletters, and membership sites."
  },
  "requirements": {
    "min_ram_mb": 512
  },
  "setup": {
    "url_path": "/ghost"
  }
}
