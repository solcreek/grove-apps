{
  "name": "uptime-kuma",
  "version": "2.14.0",
  "description": "Self-hosted monitoring tool",
  "upstream": "https://github.com/louislam/uptime-kuma",
  "license": "MIT",
  "runtime": "node",
  "base_image": "node:22-alpine",
  "entry": "server/server.js",
  "port": 3001,
  "volumes": {
    "data": "/app/data"
  },
  "env": {
    "NODE_ENV": "production"
  },
  "health_check": "/",
  "build": {
    "repo": "https://github.com/louislam/uptime-kuma.git",
    "install": "npm ci --production",
    "post_install": "npm run download-dist"
  },
  "tags": ["monitoring", "uptime", "status-page"]
}
