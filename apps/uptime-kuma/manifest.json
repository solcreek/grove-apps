{
  "schema_version": "0.1",
  "slug": "uptime-kuma",
  "name": "Uptime Kuma",
  "kind": "image",
  "version": "2.4.0",
  "description": "Self-hosted uptime / availability monitor",
  "upstream": "https://github.com/louislam/uptime-kuma",
  "license": "MIT",
  "tags": [
    "monitoring",
    "uptime",
    "status-page"
  ],
  "image": "louislam/uptime-kuma:2.4.0",
  "image_digest": "",
  "arch": [
    "amd64",
    "arm64"
  ],
  "ports": [
    {
      "name": "http",
      "container": 3001,
      "protocol": "tcp"
    }
  ],
  "volumes": [
    {
      "name": "data",
      "path": "/app/data",
      "persistent": true
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "health_check": "/",
  "update_policy": "manual",
  "display": {
    "icon": "icons/uptime-kuma.svg",
    "category": "monitoring",
    "long_description": "A self-hosted alternative to Uptime Robot. Monitors HTTP, TCP, Docker containers, and DNS with a polished UI and rich notification integrations."
  },
  "requirements": {
    "min_ram_mb": 256
  }
}
